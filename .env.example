# Backend
TEXPAD_HTTP_ADDR=:8080
TEXPAD_DATABASE_URL=postgres://texpad:texpad@localhost:5432/texpad?sslmode=disable
TEXPAD_REDIS_ADDR=localhost:6379
TEXPAD_MINIO_ENDPOINT=localhost:9000
TEXPAD_MINIO_ACCESS_KEY=minio
TEXPAD_MINIO_SECRET_KEY=minio_secret_change_me
TEXPAD_MINIO_BUCKET=texpad
TEXPAD_MINIO_USE_SSL=false
TEXPAD_JWT_SECRET=change-me-to-a-long-random-string
TEXPAD_CORS_ORIGINS=http://localhost:5173
# Optional: OpenAI-compatible API for Agent
TEXPAD_LLM_BASE_URL=
TEXPAD_LLM_API_KEY=
TEXPAD_LLM_MODEL=gpt-4o-mini
# Compile: true = 使用本机 latexmk（需已安装 TeX Live）；false = Docker 镜像编译
TEXPAD_COMPILE_NATIVE=false
# Docker 编译时使用
TEXPAD_DOCKER_BIN=docker
TEXPAD_TEXLIVE_IMAGE=texpad-texlive:local

# Frontend (Vite)
VITE_API_BASE=http://localhost:8080
VITE_COLLAB_WS=ws://localhost:1234
