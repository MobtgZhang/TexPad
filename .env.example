# Backend（本机开发：依赖端口与下方 docker-compose 宿主机映射一致）
TEXPAD_HTTP_ADDR=:18473
TEXPAD_DATABASE_URL=postgres://texpad:texpad@localhost:25432/texpad?sslmode=disable
TEXPAD_REDIS_ADDR=localhost:26379
TEXPAD_MINIO_ENDPOINT=localhost:19000
TEXPAD_MINIO_ACCESS_KEY=minio
TEXPAD_MINIO_SECRET_KEY=minio_secret_change_me
TEXPAD_MINIO_BUCKET=texpad
TEXPAD_MINIO_USE_SSL=false
TEXPAD_JWT_SECRET=change-me-to-a-long-random-string
TEXPAD_CORS_ORIGINS=http://localhost:18474
# Optional: OpenAI-compatible API for Agent
TEXPAD_LLM_BASE_URL=
TEXPAD_LLM_API_KEY=
TEXPAD_LLM_MODEL=gpt-4o-mini
# 升级代码后请执行迁移：`cd backend && go run ./cmd/migrate`（需含 compile_jobs.texlive_year 等列）
# Compile: true = 使用本机 latexmk（需已安装 TeX Live，建议 texlive-full 以免缺宏包）；false = docker run 指定镜像编译
# docker compose --profile app 启动的后端已设为 false 并挂载 docker.sock，与 texpad-texlive:latest-full 搭配使用
TEXPAD_COMPILE_NATIVE=false
# Docker 编译：单次任务超时（秒，默认 600）；`docker run --memory` 限制（默认 2048m，大文档可调 4096m）
TEXPAD_COMPILE_TIMEOUT_SEC=600
TEXPAD_COMPILE_DOCKER_MEMORY=2048m
# Docker 编译时使用（后端跑在容器里时请用绝对路径，例如 /usr/bin/docker）
TEXPAD_DOCKER_BIN=docker
# 后端在 Docker 内、通过宿主 docker.sock 跑编译容器时必填：与 compose 中命名卷一致（见 docker-compose.yml）
# TEXPAD_COMPILE_DOCKER_VOLUME=texpad_compile_workspace
# TEXPAD_COMPILE_WORKSPACE_DIR=/compile-work
# Docker 编译默认镜像（亦为未单独指定年份时的回退）
TEXPAD_TEXLIVE_IMAGE=texpad-texlive:2025
# 按年份选择（留空则回退到 TEXPAD_TEXLIVE_IMAGE）；需先 `docker compose --profile compile build texlive2024 texlive2025`
TEXPAD_TEXLIVE_IMAGE_2024=texpad-texlive:2024
TEXPAD_TEXLIVE_IMAGE_2025=texpad-texlive:2025
# 每用户 24h 内最大编译次数；0 或不设为不限制
TEXPAD_COMPILE_DAILY_LIMIT=0
# 编译失败：在编辑器「编译日志」查看 log；Docker 模式需本机可运行 docker 且镜像名与上表一致。

# Frontend (Vite)
VITE_API_BASE=http://localhost:18473
# 可选：docker compose --profile collab up 后设为 ws://localhost:18475
VITE_COLLAB_WS=
