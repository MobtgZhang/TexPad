# TeX Live medium 方案：用于 CI 或磁盘紧张环境；宏包少于 full，复杂文档可能缺包。
# 上游：https://gitlab.com/islandoftex/images/texlive
# 上游 tag 为 latest-medium（非裸 medium），与 compose build args 一致
ARG TEX_SCHEME=latest-medium
FROM registry.gitlab.com/islandoftex/images/texlive:${TEX_SCHEME}

USER root
RUN apt-get update \
	&& DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends fonts-noto-cjk \
	&& rm -rf /var/lib/apt/lists/* \
	&& fc-cache -fv

# medium 方案常缺 LaTeX/ConTeXt 中文相关集合，按需安装（体积会增大）
RUN tlmgr update --self \
	&& tlmgr install collection-langcjk collection-context

WORKDIR /work
ENV PATH="/usr/local/bin:/usr/bin:${PATH}"
ENV OSFONTDIR="/usr/share/fonts//:"

COPY verify-cjk /tmp/verify-cjk
RUN cd /tmp/verify-cjk \
	&& latexmk -xelatex -interaction=nonstopmode -halt-on-error xe.tex \
	&& latexmk -lualatex -interaction=nonstopmode -halt-on-error lua.tex \
	&& context --nonstopmode ctx.tex \
	&& rm -rf /tmp/verify-cjk

RUN latexmk -v
