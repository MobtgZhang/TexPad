# 复制为 .env.docker（已被 .gitignore 忽略），供 docker compose 变量替换与可选 env_file 使用。
# 请勿将含真实密钥的 .env.docker 提交到版本库。对外部署前必须更换全部密码与 JWT。

# --- Postgres（与 compose 中服务名 postgres 对齐）---
# 注意：pgdata 卷只在「第一次 init」时采用此处密码；若卷已存在后改密码，会导致后端 FATAL 28P01，需改回旧密码或删卷重建（见 README）。
POSTGRES_USER=texpad
POSTGRES_PASSWORD=change-me-generate-a-strong-password
POSTGRES_DB=texpad

# --- MinIO（固定 tag 见 docker-compose.yml）---
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=change-me-minio-secret

# --- TexPad 后端（profile app / collab）---
# 与 collab 服务共用；请使用 openssl rand -hex 32 等生成长随机串
TEXPAD_JWT_SECRET=change-me-long-random-jwt-secret
# 浏览器访问 Nginx 前端的源（逗号分隔多个）
TEXPAD_CORS_ORIGINS=http://localhost:18472

# 后端在容器内通过宿主 docker.sock 编译时强制要求命名卷（见 README 编译卷说明）
TEXPAD_REQUIRE_COMPILE_VOLUME=true
